function Trig_3_______uActions takes nothing returns nothing
    call YDWESetAttackDamageWeaponType(ATTACK_TYPE_SIEGE, DAMAGE_TYPE_ENHANCED, WEAPON_TYPE_WHOKNOWS)
    call YDWESetLocalVariableLocation("l", GetUnitLoc(GetTriggerUnit()))
    call YDWESetLocalVariableLocation("p", GetSpellTargetLoc())
    call YDWESetLocalVariableReal("r", AngleBetweenPoints(YDWEGetLocalVariableLocation("l"), YDWEGetLocalVariableLocation("p")))
    call YDWESetLocalVariableReal("d", DistanceBetweenPoints(YDWEGetLocalVariableLocation("l"), YDWEGetLocalVariableLocation("p")))
    call YDWETimerPatternJumpAttack(GetTriggerUnit(), YDWEGetLocalVariableReal("r"), YDWEGetLocalVariableReal("d"), 1, 0.03, 350.00, 1.00, "chest", "Abilities\\Spells\\Other\\CrushingWave\\CrushingWaveDamage.mdl")
    call RemoveLocation(YDWEGetLocalVariableLocation("l"))
    call RemoveLocation(YDWEGetLocalVariableLocation("p"))
