//===========================================================================
// Trigger: 冲锋结束6
//===========================================================================
function Trig_____________6Actions takes nothing returns nothing
    call SelectUnitForPlayerSingle(GetLastAbilityCastingUnit(), GetOwningPlayer(GetLastAbilityCastingUnit()))
    call DisplayTextToPlayer(Player(0), 0, 0, (GetUnitName(GetLastAbilityCastingUnit()) + " 释放结束冲锋技能"))
    // 让单位施法结束后不会乱跑
    call IssueImmediateOrderById(GetLastAbilityCastingUnit(), 851972)
endfunction

