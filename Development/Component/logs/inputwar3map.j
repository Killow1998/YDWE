//===========================================================================
function Trig_1_______uConditions takes nothing returns boolean
    return ((IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true) and (GetSpellAbilityId() == 'A000'))
endfunction
function Trig_1_______uActions takes nothing returns nothing
    call YDWESetAttackDamageWeaponType(ATTACK_TYPE_SIEGE, DAMAGE_TYPE_ENHANCED, WEAPON_TYPE_WHOKNOWS)
    call YDWETimerPatternRushSlide(GetTriggerUnit(), GetUnitFacing(GetTriggerUnit()), 800.00, 1, 0.03, 100.00, true, false, true, "origin", "Objects\\Spawnmodels\\Undead\\ImpaleTargetDust\\ImpaleTargetDust.mdl", "Abilities\\Spells\\Other\\CrushingWave\\CrushingWaveDamage.mdl")
endfunction
//===========================================================================
function InitTrig_1_______u takes nothing returns nothing
    set gg_trg_1_______u = CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_1_______u, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_1_______u, Condition(function Trig_1_______uConditions))
    call TriggerAddAction(gg_trg_1_______u, function Trig_1_______uActions)
endfunction
//===========================================================================
// Trigger: 2_жңҲзҘһз®ӯ
//
// (YDWEGetUnitID
//===========================================================================
function Trig_2__________uConditions takes nothing returns boolean
    return ((IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true) and (GetSpellAbilityId() == 'A001'))
endfunction
function Trig_2__________uActions takes nothing returns nothing
    call YDWESetAttackDamageWeaponType(ATTACK_TYPE_SIEGE, DAMAGE_TYPE_ENHANCED, WEAPON_TYPE_WHOKNOWS)
    call YDWESetLocalVariableLocation("l", GetUnitLoc(GetTriggerUnit()))
    call YDWESetLocalVariableLocation("p", GetSpellTargetLoc())
    call YDWESetLocalVariableReal("r", AngleBetweenPoints(YDWEGetLocalVariableLocation("l"), YDWEGetLocalVariableLocation("p")))
    call YDWESetLocalVariableUnit("u", CreateUnitAtLoc(GetOwningPlayer(GetTriggerUnit()), 'nalb', YDWEGetLocalVariableLocation("l"), YDWEGetLocalVariableReal("r")))
    call YDWESaveUnitByString(I2S(YDWEH2I(YDWEGetLocalVariableUnit("u"))), "жңҲзҘһз®ӯж–Ҫж”ҫиҖ…", GetTriggerUnit())
    call YDWESaveUnitByInteger(YDWEH2I(YDWEGetLocalVariableUnit("u")), 11, GetTriggerUnit())
    call YDWETimerPatternMoonPriestessArrow(YDWEGetLocalVariableUnit("u"), YDWEGetLocalVariableReal("r"), 1350.00, 2.00, 0.03, GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit()), 'AHtb', 'npng', "thunderbolt", "overhead", "\"Objects\\\\Spawnmodels\\\\Undead\\\\ImpaleTargetDust\\\\ImpaleTargetDust.mdl\"")
    call RemoveLocation(YDWEGetLocalVariableLocation("l"))
    call RemoveLocation(YDWEGetLocalVariableLocation("p"))
    call YDWELocalVariableEnd()
endfunction
//===========================================================================
